
{{>header}}

<section class="mx-auto w-full max-w-md">
  <div class="card">
    <h1 class="mb-1 text-center text-xl font-semibold">Admin Reset Password</h1>
    <p class="mb-6 text-center text-sm text-slate-500 dark:text-slate-400">
      Set a secure new password for admin account.
    </p>

    <form id="admin-reset-form" action="" method="post" class="space-y-4">
      <input type="hidden" name="user_id" value="{{user_id}}" />
      <div class="space-y-2">
        <div class="flex items-center justify-between">
          <label class="text-xs font-medium text-slate-600 dark:text-slate-300">New Password</label>
          <button id="admin-reset-toggle" type="button" class="text-[11px] font-medium text-primary-600 dark:text-primary-300">Show</button>
        </div>
        <input id="admin-reset-password" type="password" name="password" class="input-base" required minlength="8" />
        <div class="h-1.5 w-full rounded-full bg-slate-200"><div id="admin-reset-bar" class="h-1.5 w-0 rounded-full transition-all"></div></div>
        <p id="admin-reset-label" class="text-[11px] text-slate-500 dark:text-slate-400"></p>
      </div>

      <button id="admin-reset-btn" class="btn-primary" type="submit">
        <span id="admin-reset-text">Reset Password</span>
        <span id="admin-reset-loading" class="ml-2 hidden h-4 w-4 animate-spin rounded-full border-2 border-white/70 border-t-transparent"></span>
      </button>
    </form>
  </div>
</section>

<script>
  (function () {
    bindPasswordToggle("admin-reset-password", "admin-reset-toggle");
    bindPasswordStrength("admin-reset-password", "admin-reset-bar", "admin-reset-label");
    const form = document.getElementById("admin-reset-form");
    const btn = document.getElementById("admin-reset-btn");
    const loading = document.getElementById("admin-reset-loading");
    const text = document.getElementById("admin-reset-text");
    const pass = document.getElementById("admin-reset-password");
    form.addEventListener("submit", function (e) {
      if ((pass.value || "").length < 8) {
        e.preventDefault();
        showToast("Password should be at least 8 characters.", "error");
        return;
      }
      btn.disabled = true;
      loading.classList.remove("hidden");
      text.textContent = "Resetting...";
    });
  })();
</script>

{{>footer}}
