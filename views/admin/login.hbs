
{{>header}}

<section class="mx-auto w-full max-w-5xl">
  <div class="grid gap-5 lg:grid-cols-[1fr_1.05fr]">
    <div class="card panel-glow hidden lg:block">
      <span class="inline-flex rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700 dark:border-amber-400/30 dark:bg-amber-900/30 dark:text-amber-300">Admin Zone</span>
      <h2 class="display-font mt-4 text-3xl font-semibold leading-tight">Control users, exports and security flows from one dashboard</h2>
      <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">
        This panel is optimized for quick operations with clear action feedback.
      </p>
      <div class="mt-6 grid gap-2 text-sm text-slate-600 dark:text-slate-300">
        <div class="rounded-lg border border-slate-200 bg-white/60 px-3 py-2 dark:border-slate-700 dark:bg-slate-900/50">User create, edit and delete controls</div>
        <div class="rounded-lg border border-slate-200 bg-white/60 px-3 py-2 dark:border-slate-700 dark:bg-slate-900/50">Excel and PDF export actions</div>
        <div class="rounded-lg border border-slate-200 bg-white/60 px-3 py-2 dark:border-slate-700 dark:bg-slate-900/50">Animated popup success and errors</div>
      </div>
    </div>

    <div class="card panel-glow">
      <h1 class="display-font mb-1 text-center text-2xl font-semibold">Admin Login</h1>
      <p class="mb-6 text-center text-sm text-slate-500 dark:text-slate-400">
        Sign in to manage users and platform data.
      </p>

      <form id="admin-login-form" action="" method="post" class="space-y-4">
        <div class="space-y-1.5">
          <label class="text-xs font-medium text-slate-600 dark:text-slate-300">Email</label>
          <input class="input-base" type="email" name="email" required placeholder="admin@example.com" />
        </div>
        <div class="space-y-1.5">
          <div class="flex items-center justify-between">
            <label class="text-xs font-medium text-slate-600 dark:text-slate-300">Password</label>
            <button type="button" id="admin-password-toggle" class="text-[11px] font-medium text-primary-600 dark:text-primary-300">Show</button>
          </div>
          <input id="admin-password" class="input-base" type="password" name="password" required placeholder="Password" />
        </div>
        <a href="/admin/forget" class="block text-right text-xs font-medium text-primary-600 dark:text-primary-300">Forgot password?</a>
        <button id="admin-login-btn" class="btn-primary" type="submit">
          <span id="admin-login-text">Login</span>
          <span id="admin-login-loading" class="ml-2 hidden h-4 w-4 animate-spin rounded-full border-2 border-white/70 border-t-transparent"></span>
        </button>
      </form>

      {{#if message}}
      <script>showToast("{{message}}", "{{messageType}}");</script>
      {{/if}}
    </div>
  </div>
</section>

<script>
  (function () {
    bindPasswordToggle("admin-password", "admin-password-toggle");
    const form = document.getElementById("admin-login-form");
    const btn = document.getElementById("admin-login-btn");
    const loading = document.getElementById("admin-login-loading");
    const text = document.getElementById("admin-login-text");
    form.addEventListener("submit", function () {
      btn.disabled = true;
      loading.classList.remove("hidden");
      text.textContent = "Signing in...";
    });
  })();
</script>

{{>footer}}
