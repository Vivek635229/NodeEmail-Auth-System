
{{>header}}

<section class="mx-auto w-full max-w-md">
  <div class="card">
    <h1 class="mb-1 text-center text-xl font-semibold">Edit User</h1>
    <p class="mb-6 text-center text-sm text-slate-500 dark:text-slate-400">
      Update details and toggle user verification status.
    </p>

    <form id="admin-edit-user-form" action="" method="post" class="space-y-4">
      <div class="space-y-1.5">
        <label class="text-xs font-medium text-slate-600 dark:text-slate-300">Name</label>
        <input class="input-base" type="text" name="name" value="{{user.name}}" required />
      </div>
      <div class="space-y-1.5">
        <label class="text-xs font-medium text-slate-600 dark:text-slate-300">Email</label>
        <input class="input-base" type="email" name="email" value="{{user.email}}" required />
      </div>
      <div class="space-y-1.5">
        <label class="text-xs font-medium text-slate-600 dark:text-slate-300">Mobile</label>
        <input class="input-base" type="text" name="mobile" value="{{user.mobile}}" required />
      </div>

      <div class="rounded-lg border border-slate-200 p-3 dark:border-slate-700">
        <p class="text-xs font-medium text-slate-600 dark:text-slate-300">User Verification</p>
        <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Click badge to toggle verification on save.</p>
        <button type="button" id="verification-toggle" class="mt-2 inline-flex rounded-full px-3 py-1 text-xs font-semibold"></button>
      </div>

      <input type="hidden" id="verify-state" name="is_varified" value="{{user.is_varified}}" />
      <input type="hidden" name="id" value="{{user._id}}" />

      <div class="grid gap-3 sm:grid-cols-2">
        <button id="admin-edit-user-btn" class="btn-primary" type="submit">
          <span id="admin-edit-user-text">Update User</span>
          <span id="admin-edit-user-loading" class="ml-2 hidden h-4 w-4 animate-spin rounded-full border-2 border-white/70 border-t-transparent"></span>
        </button>
        <a href="/admin/dashboard" class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-600 dark:text-slate-200 dark:hover:bg-slate-800">Go Back</a>
      </div>
    </form>
    {{#if message}}
    <script>showToast("{{message}}", "{{messageType}}");</script>
    {{/if}}
  </div>
</section>

<script>
  (function () {
    const toggle = document.getElementById("verification-toggle");
    const stateInput = document.getElementById("verify-state");
    const form = document.getElementById("admin-edit-user-form");
    const btn = document.getElementById("admin-edit-user-btn");
    const loading = document.getElementById("admin-edit-user-loading");
    const text = document.getElementById("admin-edit-user-text");

    function paint() {
      const active = stateInput.value === "1";
      toggle.textContent = active ? "Verified" : "Not Verified";
      toggle.className = active
        ? "mt-2 inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300"
        : "mt-2 inline-flex rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-700 dark:bg-red-900/40 dark:text-red-300";
    }

    paint();
    toggle.addEventListener("click", function () {
      stateInput.value = stateInput.value === "1" ? "0" : "1";
      paint();
    });

    form.addEventListener("submit", function () {
      btn.disabled = true;
      loading.classList.remove("hidden");
      text.textContent = "Updating...";
    });
  })();
</script>

{{>footer}}
