{{>header}}

<section class="mx-auto w-full max-w-3xl">
  <div class="card card-lg">
    <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold">Welcome, {{user.name}}</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400">
          Your account overview and profile details.
        </p>
      </div>
      <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300">
        User Dashboard
      </span>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-700">
        <p class="text-xs text-slate-500">Email</p>
        <p class="mt-1 text-sm font-semibold">{{user.email}}</p>
      </div>
      <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-700">
        <p class="text-xs text-slate-500">Mobile</p>
        <p class="mt-1 text-sm font-semibold">{{user.mobile}}</p>
      </div>
      <div class="rounded-xl border border-slate-200 p-4 dark:border-slate-700 sm:col-span-2">
        <p class="text-xs text-slate-500">Email verification</p>
        {{#ifeq user.is_varified 1}}
        <p class="mt-1 inline-flex items-center gap-2 rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300">Verified</p>
        {{else}}
        <p class="mt-1 inline-flex items-center gap-2 rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-700 dark:bg-red-900/40 dark:text-red-300">Not Verified</p>
        {{/ifeq}}
      </div>
    </div>

    <div class="mt-6 grid gap-3 sm:grid-cols-2">
      <a href="/editProfile?id={{user._id}}" class="btn-primary text-center">Edit Profile</a>
      <a href="/logout" class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-600 dark:text-slate-200 dark:hover:bg-slate-800">Logout</a>
    </div>
  </div>
</section>

{{#if statusMessage}}
<script>
  showToast("{{statusMessage}}", "{{statusType}}");
</script>
{{/if}}

{{>footer}}