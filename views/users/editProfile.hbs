
{{>header}}

<section class="mx-auto w-full max-w-md">
  <div class="card">
    <h1 class="mb-1 text-center text-xl font-semibold">Edit Profile</h1>
    <p class="mb-6 text-center text-sm text-slate-500 dark:text-slate-400">
      Keep your account details updated.
    </p>

    <form id="edit-profile-form" action="" method="post" class="space-y-4">
      <input type="hidden" name="user_id" value="{{user._id}}" />

      <div class="space-y-1.5">
        <label class="text-xs font-medium text-slate-600 dark:text-slate-300">Name</label>
        <input class="input-base" type="text" name="name" value="{{user.name}}" required />
      </div>

      <div class="space-y-1.5">
        <label class="text-xs font-medium text-slate-600 dark:text-slate-300">Email</label>
        <input class="input-base" type="email" name="email" value="{{user.email}}" required />
      </div>

      <div class="space-y-1.5">
        <label class="text-xs font-medium text-slate-600 dark:text-slate-300">Mobile</label>
        <input class="input-base" type="text" name="mobile" value="{{user.mobile}}" required />
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        <button id="edit-save-btn" class="btn-primary" type="submit">
          <span id="edit-save-text">Save Changes</span>
          <span id="edit-save-loading" class="ml-2 hidden h-4 w-4 animate-spin rounded-full border-2 border-white/70 border-t-transparent"></span>
        </button>
        <a href="/home" class="inline-flex items-center justify-center rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-600 dark:text-slate-200 dark:hover:bg-slate-800">Cancel</a>
      </div>
    </form>
  </div>
</section>

<script>
  (function () {
    const form = document.getElementById("edit-profile-form");
    const btn = document.getElementById("edit-save-btn");
    const loading = document.getElementById("edit-save-loading");
    const text = document.getElementById("edit-save-text");
    form.addEventListener("submit", function () {
      btn.disabled = true;
      loading.classList.remove("hidden");
      text.textContent = "Saving...";
    });
  })();
</script>

{{>footer}}
