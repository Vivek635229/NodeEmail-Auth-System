
{{>header}}

<section class="mx-auto w-full max-w-5xl">
  <div class="grid gap-5 lg:grid-cols-[1.05fr_1fr]">
    <aside class="card panel-glow hidden lg:flex lg:flex-col lg:justify-between">
      <div>
        <span class="inline-flex rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700 dark:border-sky-400/30 dark:bg-sky-900/30 dark:text-sky-300">Start Smart</span>
        <h2 class="display-font mt-4 text-3xl font-semibold leading-tight">Build your secure identity in minutes</h2>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">
          One registration gives you email verification, password reset, and personal profile controls.
        </p>
      </div>
      <ul class="mt-8 space-y-2 text-sm text-slate-600 dark:text-slate-300">
        <li class="rounded-lg border border-slate-200 bg-white/60 px-3 py-2 dark:border-slate-700 dark:bg-slate-900/50">Real-time password strength check</li>
        <li class="rounded-lg border border-slate-200 bg-white/60 px-3 py-2 dark:border-slate-700 dark:bg-slate-900/50">Animated action popups</li>
        <li class="rounded-lg border border-slate-200 bg-white/60 px-3 py-2 dark:border-slate-700 dark:bg-slate-900/50">Professional email verification flow</li>
      </ul>
    </aside>

    <div class="card panel-glow">
      <h1 class="display-font mb-1 text-center text-2xl font-semibold tracking-tight">
        Create your account
      </h1>
      <p class="mb-6 text-center text-sm text-slate-500 dark:text-slate-400">
        Start using your secure authentication dashboard.
      </p>

    <form
      id="register-form"
      action="/Register"
      method="post"
      class="space-y-4"
      autocomplete="on"
    >
      <div class="space-y-1.5">
        <label for="reg-name" class="text-xs font-medium text-slate-600 dark:text-slate-300"
          >Full name</label
        >
        <input
          id="reg-name"
          name="name"
          type="text"
          required
          minlength="2"
          class="input-base"
          placeholder="John Doe"
        />
      </div>

      <div class="space-y-1.5">
        <label for="reg-email" class="text-xs font-medium text-slate-600 dark:text-slate-300"
          >Email</label
        >
        <input
          id="reg-email"
          name="email"
          type="email"
          required
          class="input-base"
          placeholder="you@example.com"
        />
      </div>

      <div class="space-y-1.5">
        <label for="reg-mobile" class="text-xs font-medium text-slate-600 dark:text-slate-300"
          >Mobile</label
        >
        <input
          id="reg-mobile"
          name="mobile"
          type="tel"
          required
          pattern="[0-9]{8,15}"
          class="input-base"
          placeholder="Enter mobile number"
        />
        <p class="text-[11px] text-slate-400">
          Digits only, no spaces or symbols.
        </p>
      </div>

      <div class="space-y-2">
        <div class="flex items-center justify-between">
          <label
            for="reg-password"
            class="text-xs font-medium text-slate-600 dark:text-slate-300"
            >Password</label
          >
          <button
            type="button"
            id="reg-password-toggle"
            class="text-[11px] font-medium text-primary-600 hover:text-primary-700 dark:text-primary-300"
          >
            Show
          </button>
        </div>
        <div class="relative">
          <input
            id="reg-password"
            name="password"
            type="password"
            required
            minlength="8"
            class="input-base pr-16"
            placeholder="At least 8 characters"
          />
        </div>
        <div class="mt-1.5 space-y-1">
          <div class="h-1.5 w-full rounded-full bg-slate-200">
            <div
              id="reg-password-bar"
              class="h-1.5 w-0 rounded-full bg-slate-200 transition-all"
            ></div>
          </div>
          <p
            id="reg-password-label"
            class="text-[11px] font-medium text-slate-500 dark:text-slate-400"
          ></p>
          <p class="text-[11px] text-slate-400">
            Use at least 8 characters with a mix of letters, numbers, and symbols.
          </p>
        </div>
      </div>

      <button
        id="register-submit"
        type="submit"
        class="btn-primary mt-1"
      >
        <span id="register-submit-text">Create account</span>
        <span
          id="register-loading"
          class="ml-2 hidden h-4 w-4 animate-spin rounded-full border-2 border-white/70 border-t-transparent"
        ></span>
      </button>
    </form>

      <p class="mt-4 text-center text-xs text-slate-500 dark:text-slate-400">
        Already have an account?
        <a
          href="/login"
          class="font-semibold text-primary-600 hover:text-primary-700 dark:text-primary-300"
          >Login</a
        >
      </p>

      {{#if message}}
      <script>
        showToast("{{message}}", "{{messageType}}");
      </script>
      {{/if}}
    </div>
  </div>
</section>

<script>
  (function () {
    const form = document.getElementById("register-form");
    const submitBtn = document.getElementById("register-submit");
    const loading = document.getElementById("register-loading");
    const submitText = document.getElementById("register-submit-text");

    bindPasswordToggle("reg-password", "reg-password-toggle");
    bindPasswordStrength("reg-password", "reg-password-bar", "reg-password-label");

    if (!form || !submitBtn) return;

    form.addEventListener("submit", function (e) {
      const name = document.getElementById("reg-name");
      const email = document.getElementById("reg-email");
      const mobile = document.getElementById("reg-mobile");
      const password = document.getElementById("reg-password");

      if (!name.value || !email.value || !mobile.value || !password.value) {
        e.preventDefault();
        showToast("Please fill in all the fields.", "error");
        return;
      }

      if (password.value.length < 8) {
        e.preventDefault();
        showToast("Password should be at least 8 characters long.", "error");
        return;
      }

      submitBtn.disabled = true;
      if (loading && submitText) {
        loading.classList.remove("hidden");
        submitText.textContent = "Creating account...";
      }
    });
  })();
</script>

{{>footer}}
