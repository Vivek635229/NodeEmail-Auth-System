
{{>header}}

<section class="mx-auto w-full max-w-5xl">
  <div class="grid gap-5 lg:grid-cols-[1.05fr_1fr]">
    <aside class="card panel-glow hidden lg:flex lg:flex-col lg:justify-between">
      <div>
        <span class="inline-flex rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 dark:border-emerald-400/30 dark:bg-emerald-900/30 dark:text-emerald-300">Secure Access</span>
        <h2 class="display-font mt-4 text-3xl font-semibold leading-tight">Login to your professional auth workspace</h2>
        <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">
          Fast, secure and beautifully organized user management with email workflows.
        </p>
      </div>
      <ul class="mt-8 space-y-2 text-sm text-slate-600 dark:text-slate-300">
        <li class="rounded-lg border border-slate-200 bg-white/60 px-3 py-2 dark:border-slate-700 dark:bg-slate-900/50">Protected session login</li>
        <li class="rounded-lg border border-slate-200 bg-white/60 px-3 py-2 dark:border-slate-700 dark:bg-slate-900/50">Instant action popups</li>
        <li class="rounded-lg border border-slate-200 bg-white/60 px-3 py-2 dark:border-slate-700 dark:bg-slate-900/50">Email-based verification and reset</li>
      </ul>
    </aside>

    <div class="card panel-glow">
      <h1 class="display-font mb-1 text-center text-2xl font-semibold tracking-tight">
        Welcome back
      </h1>
      <p class="mb-6 text-center text-sm text-slate-500 dark:text-slate-400">
        Sign in to access your dashboard.
      </p>

      <form
        id="login-form"
        action="/login"
        method="post"
        class="space-y-4"
        autocomplete="on"
      >
        <div class="space-y-1.5">
          <label for="login-email" class="text-xs font-medium text-slate-600 dark:text-slate-300"
            >Email</label
          >
          <input
            id="login-email"
            name="email"
            type="email"
            required
            class="input-base"
            placeholder="you@example.com"
          />
        </div>

        <div class="space-y-1.5">
          <div class="flex items-center justify-between">
            <label
              for="login-password"
              class="text-xs font-medium text-slate-600 dark:text-slate-300"
              >Password</label
            >
            <button
              type="button"
              id="login-password-toggle"
              class="text-[11px] font-medium text-primary-600 hover:text-primary-700 dark:text-primary-300"
            >
              Show
            </button>
          </div>
          <div class="relative">
            <input
              id="login-password"
              name="password"
              type="password"
              required
              minlength="6"
              class="input-base pr-16"
              placeholder="Password"
            />
          </div>
        </div>

        <div class="flex flex-wrap items-center justify-between gap-2 text-xs">
          <a
            href="/forget"
            class="font-medium text-primary-600 hover:text-primary-700 dark:text-primary-300 dark:hover:text-primary-200"
            >Forgot password?</a
          >
          <a
            href="/verification"
            class="font-medium text-slate-500 hover:text-primary-600 dark:text-slate-300 dark:hover:text-primary-300"
            >Verify email</a
          >
        </div>

        <button
          id="login-submit"
          type="submit"
          class="btn-primary mt-2"
        >
          <span id="login-submit-text">Login</span>
          <span
            id="login-loading"
            class="ml-2 hidden h-4 w-4 animate-spin rounded-full border-2 border-white/70 border-t-transparent"
          ></span>
        </button>
      </form>

      <p class="mt-4 text-center text-xs text-slate-500 dark:text-slate-400">
        Don’t have an account?
        <a
          href="/Register"
          class="font-semibold text-primary-600 hover:text-primary-700 dark:text-primary-300"
          >Create account</a
        >
      </p>

      {{#if message}}
      <script>
        showToast("{{message}}", "{{messageType}}");
      </script>
      {{/if}}
    </div>
  </div>
</section>

<script>
  // Simple client-side validation + loading state
  (function () {
    const form = document.getElementById("login-form");
    const submitBtn = document.getElementById("login-submit");
    const loading = document.getElementById("login-loading");
    const submitText = document.getElementById("login-submit-text");

    bindPasswordToggle("login-password", "login-password-toggle");

    if (!form || !submitBtn) return;

    form.addEventListener("submit", function (e) {
      const email = document.getElementById("login-email");
      const password = document.getElementById("login-password");

      if (!email.value || !password.value) {
        e.preventDefault();
        showToast("Please fill in both email and password.", "error");
        return;
      }

      if (password.value.length < 6) {
        e.preventDefault();
        showToast("Password should be at least 6 characters.", "error");
        return;
      }

      submitBtn.disabled = true;
      if (loading && submitText) {
        loading.classList.remove("hidden");
        submitText.textContent = "Signing in...";
      }
    });
  })();
</script>

{{>footer}}
