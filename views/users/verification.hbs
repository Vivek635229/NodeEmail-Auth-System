
{{>header}}

<section class="mx-auto w-full max-w-md">
  <div class="card">
    <h1 class="mb-1 text-center text-xl font-semibold">Email Verification</h1>
    <p class="mb-6 text-center text-sm text-slate-500 dark:text-slate-400">
      Resend your account verification email.
    </p>

    <form id="verification-form" action="" method="post" class="space-y-4">
      <div class="space-y-1.5">
        <label class="text-xs font-medium text-slate-600 dark:text-slate-300">Email</label>
        <input class="input-base" type="email" name="email" placeholder="you@example.com" required />
      </div>
      <button id="verification-submit" class="btn-primary" type="submit">
        <span id="verification-submit-text">Send Verification Link</span>
        <span id="verification-loading" class="ml-2 hidden h-4 w-4 animate-spin rounded-full border-2 border-white/70 border-t-transparent"></span>
      </button>
    </form>

    {{#if message}}
    <script>showToast("{{message}}", "{{messageType}}");</script>
    {{/if}}
  </div>
</section>

<script>
  (function () {
    const form = document.getElementById("verification-form");
    const btn = document.getElementById("verification-submit");
    const loading = document.getElementById("verification-loading");
    const text = document.getElementById("verification-submit-text");
    form.addEventListener("submit", function () {
      btn.disabled = true;
      loading.classList.remove("hidden");
      text.textContent = "Sending...";
    });
  })();
</script>

{{>footer}}
