
{{>header}}

<section class="mx-auto w-full max-w-md">
  <div class="card">
    <h1 class="mb-1 text-center text-xl font-semibold">Reset password</h1>
    <p class="mb-6 text-center text-sm text-slate-500 dark:text-slate-400">
      Create a new strong password for your account.
    </p>

    <form id="reset-form" action="" method="post" class="space-y-4">
      <input type="hidden" name="user_id" value="{{user_id}}" />
      <div class="space-y-2">
        <div class="flex items-center justify-between">
          <label for="user-reset-password" class="text-xs font-medium text-slate-600 dark:text-slate-300">New Password</label>
          <button type="button" id="user-reset-toggle" class="text-[11px] font-medium text-primary-600 dark:text-primary-300">Show</button>
        </div>
        <input
          id="user-reset-password"
          type="password"
          name="password"
          class="input-base"
          minlength="8"
          required
          placeholder="At least 8 characters"
        />
        <div class="h-1.5 w-full rounded-full bg-slate-200">
          <div id="user-reset-bar" class="h-1.5 w-0 rounded-full transition-all"></div>
        </div>
        <p id="user-reset-label" class="text-[11px] text-slate-500 dark:text-slate-400"></p>
      </div>

      <button id="reset-submit" class="btn-primary" type="submit">
        <span id="reset-submit-text">Reset Password</span>
        <span id="reset-loading" class="ml-2 hidden h-4 w-4 animate-spin rounded-full border-2 border-white/70 border-t-transparent"></span>
      </button>
    </form>
  </div>
</section>

<script>
  (function () {
    bindPasswordToggle("user-reset-password", "user-reset-toggle");
    bindPasswordStrength("user-reset-password", "user-reset-bar", "user-reset-label");
    const form = document.getElementById("reset-form");
    const password = document.getElementById("user-reset-password");
    const submitBtn = document.getElementById("reset-submit");
    const loading = document.getElementById("reset-loading");
    const text = document.getElementById("reset-submit-text");
    form.addEventListener("submit", function (e) {
      if ((password.value || "").length < 8) {
        e.preventDefault();
        showToast("Password should be at least 8 characters.", "error");
        return;
      }
      submitBtn.disabled = true;
      loading.classList.remove("hidden");
      text.textContent = "Resetting...";
    });
  })();
</script>

{{>footer}}
